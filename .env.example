# Gemini API anahtarı
GEMINI_API_KEY=buraya_api_anahtarinizi_yazin

# Firebase yapılandırması
# 1) Anahtarı JSON dosyası olarak kullanmak için:
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# 2) Alternatif olarak JSON içeriğini doğrudan ENV içinde saklayabilirsiniz:
# FIREBASE_SERVICE_ACCOUNT_JSON={...}

# İsteğe bağlı koleksiyon öneki
FIREBASE_COLLECTION_PREFIX=finans_asistani
